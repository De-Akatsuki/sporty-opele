# ============================================================
# .env.example — Sporty-Opele
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git.
# ============================================================

# ── Environment ─────────────────────────────────────────────
ENV=development   # development | production

# ── Local PostgreSQL (Docker) ────────────────────────────────
LOCAL_DB_URL=postgresql://sporty:sporty@localhost:5432/sporty_opele

# ── Supabase (Production) ────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=your-supabase-anon-or-service-role-key
SUPABASE_DB_URL=postgresql://postgres:your-db-password@db.your-project-ref.supabase.co:5432/postgres

postgresql://postgres:[YOUR-PASSWORD]@db.fmvxhkpwhnfmfwbfbnbr.supabase.co:5432/postgres

# ── Airflow ──────────────────────────────────────────────────
# Generate FERNET_KEY with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=your-generated-fernet-key-here
AIRFLOW_SECRET_KEY=your-random-secret-key-here
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_EMAIL=admin@sporty-opele.local

# ── External Data APIs ───────────────────────────────────────
API_FOOTBALL_KEY=your-api-football-key-here

# ── App Paths ────────────────────────────────────────────────
DATA_DIR=./data
MODEL_DIR=./models
